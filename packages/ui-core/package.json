{
  "name": "zerithdb-ui-core",
  "version": "0.1.0",
  "description": "Framework agnostic core for ZerithDB CRDT UI components",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "zerithdb-sdk": "workspace:*",
    "zerithdb-core": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "zerithdb-eslint-config": "workspace:*",
    "zerithdb-tsconfig": "workspace:*"
  }
}
